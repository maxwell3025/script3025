# :=
let inductive_endomophism_preimage:
  Pi(P: mapsto U Type).
  Pi(P_is_inductive: inductive(P)).
  Pi(u: U).
    let all_predecessors_satisfy_preimage: Type :=
      Pi(v: U).
      implies (sigma(u)(v)) (P(tau(sigma(v))))
    in
    implies all_predecessors_satisfy_preimage (P(tau(sigma(u))))
:=
  lambda(P: mapsto U Type).
  lambda(P_is_inductive: inductive(P)).
  lambda(u: U).
  lambda(all_predecessors_satisfy_preimage:
    Pi(v: U).
      implies (sigma u v) (P(tau(sigma(v))))
  ).

    let all_predecessors_of_tsu_in_P:
      Pi(w: U).
      implies (sigma(tau(sigma(u))) w)
      (P w)
    :=
      lambda(w: U).
      lambda(w_pred_of_tsu: sigma(tau(sigma(u)))(w)).
        let mapped_pred_set_u:
          mapsto U Type
        :=
          set_builder (lambda x: U. tau(sigma(k))) (sigma(u))
        in
        
        let mapped_pred_set_u_subset_P:
          Pi(x: U).
          implies (mapped_pred_set_u(x))
          (P(x))
        :=
          lambda x: U.
          lambda x_in_mapped_pred_set_u: mapped_pred_set_u x.
          # By the structure of the set builder notation, x_in_mapped_pred_set_u is a function that gives evidence that
          # x is in every set that contains all mapped elements.
          let P_satisfies_superset:
            Pi 
          :=
            TODO
          in
          TODO
        in

        let w_in_mapped_pred_set_u:
          mapped_pred_set_u w
        :=
          # Remember that this just beta-reduces
          w_pred_of_tsu
        in

        set_builder_membership w
    in

    let tsu_in_P:
      P(tau(sigma(u)))
    :=
      P_is_inductive (tau(sigma(u))) stsu_subset_P
    in

    tsu_in_P
in

let well_founded:
  mapsto U Type
:=
  lambda(u: U).
  Pi(P: mapsto U Type).
    implies (inductive(P)) (P(u))
in

0

