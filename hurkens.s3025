#!./build/script3025_bin/script3025

let implies:
  Pi(A: Type).
  Pi(B: Type).
    Type
:=
  lambda(A: Type).
  lambda(B: Type).
    Pi(_: A). B
in

let mapsto:
  Pi(A: Type 1).
  Pi(B: Type 1).
    Type 1
:=
  lambda(A: Type 1).
  lambda(B: Type 1).
    Pi(_: A). B
in

let set_builder_generic:
  Pi(A: Type 1).
  Pi(B: Type 1).
  Pi(mapping: mapsto A B).
  Pi(condition: mapsto A Type).
  mapsto B Type
:=
  lambda(A: Type 1).
  lambda(B: Type 1).
  lambda(mapping: mapsto A B).
  lambda(condition: mapsto A Type).
  lambda(b: B).
    Pi(P: mapsto B Type).
    Pi(_: Pi(x: A). implies (condition x) (P(mapping x))).
    P b
in

let U: Type 1 :=
  Pi(X: Type 1).
  mapsto (mapsto (mapsto X Type)(X))
  (mapsto X Type)
in

# let set_builder:
#   Pi(mapping: mapsto U U).
#   Pi(condition: mapsto U Type).
#   mapsto U Type
# :=
